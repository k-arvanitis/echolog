# --- Required secrets ---
GROQ_API_KEY=
OPENAI_API_KEY=
HF_TOKEN=

# --- ASR / pipeline ---
MIE_ASR_MODEL_NAME=whisper-large-v3
MIE_ASR_CHUNK_SECONDS=600
MIE_DIARIZATION_MODEL_NAME=pyannote/speaker-diarization-3.1
MIE_LANGUAGE=en
MIE_DEVICE=auto

# --- Analytics + RAG ---
MIE_ANALYTICS_ENABLED=true
MIE_ANALYTICS_MODEL_NAME=llama-3.1-8b-instant
MIE_RAG_ENABLED=true
MIE_RAG_MODEL_NAME=llama-3.3-70b-versatile
MIE_RAG_EVAL_JUDGE_MODEL=gpt-4.1-mini

# --- Storage / runtime ---
MIE_DATA_DIR=data
MIE_OUTPUT_DIR=outputs
MIE_MAX_UPLOAD_MB=500
MIE_MAX_DURATION_SECONDS=14400

# --- API ---
MIE_API_HOST=0.0.0.0
MIE_API_PORT=8001
MIE_UI_TITLE=Recall — Meeting Intelligence
# JSON list. Set to ["*"] only for local dev.
MIE_CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- Privacy ---
MIE_DEFAULT_RETENTION_DAYS=90
MIE_DELETE_RAW_AUDIO_AFTER_PROCESSING=false

# --- Infra ---
DATABASE_URL=postgresql+psycopg://mie:mie@localhost:55432/mie
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- Vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=meeting_transcript_md
DENSE_MODEL=nomic-embed-text
DENSE_DIM=768
SPARSE_MODEL=Qdrant/bm25

# --- Frontend ---
# Used by the Next.js app; expose as NEXT_PUBLIC_API_URL in frontend/.env.local
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
